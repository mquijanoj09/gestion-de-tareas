# Postgres
POSTGRES_USER=trello
POSTGRES_PASSWORD=trello
POSTGRES_DB=trello
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql://trello:trello@postgres:5432/trello?schema=public
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost
LOG_LEVEL=info

# Frontend (build-time)
VITE_API_URL=/api
